# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Telegram Bot (notifications) ────────────────────────────────────────────
# Username publique du bot (sans @) — affiché dans les instructions de l'app
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=YourBotUsername
# Token secret du bot — utilisé par le webhook serveur uniquement (jamais côté client)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── Supabase Service Role ────────────────────────────────────────────────────
# Réservé aux scripts serveur (webhook Telegram) — JAMAIS exposé côté client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
