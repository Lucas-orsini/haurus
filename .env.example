# === Clés restaurées automatiquement par l'audit env-vars ===
# Ces variables existaient avant cette run et sont toujours utilisées
# par le code. Le LLM les avait supprimées par erreur.
# Telegram Bot API token — https://core.telegram.org/bots/tutorial#creating-your-first-bot
TELEGRAM_BOT_TOKEN=
# Used for HMAC-SHA256 signature verification on incoming webhook requests.
TELEGRAM_BOT_SECRET=
# du .env.example. Configure-les dans Vercel ou ton .env.local.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
# === Fin des clés restaurées ===

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (optional — for Sign in with Google)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# PostHog Analytics — récupère ta clé sur https://eu.posthog.com → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_mX5zZik7gN24hgZvaTWjatGkXjitkECEjzxstjYe2Xmm
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Resend — récupère ta clé sur https://resend.com/api-keys
RESEND_API_KEY=
# Email expéditeur — doit correspondre à un domaine vérifié dans Resend Dashboard → Domains
# En dev tu peux utiliser onboarding@resend.dev (envoie uniquement vers l'owner du compte)
RESEND_FROM_EMAIL=hello@yourdomain.com
# URL de base de l'app (pour les liens unsubscribe dans les emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
